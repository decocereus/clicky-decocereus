{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd web && bun install --frozen-lockfile",
  "buildCommand": "cd web && bun run build",
  "outputDirectory": "web/dist",
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "https://backend.clickyhq.com/v1/$1"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "https://backend.clickyhq.com/api/auth/$1"
    },
    {
      "src": "/health",
      "dest": "https://backend.clickyhq.com/health"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
